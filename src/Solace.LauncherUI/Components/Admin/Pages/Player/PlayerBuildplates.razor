@page "/Admin/Players/{AccountId}/Buildplates"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using System.Diagnostics
@using Microsoft.EntityFrameworkCore
@using Serilog
@using Solace.BuildplateImporter
@using Solace.BuildplateRenderer
@using Solace.DB
@using Solace.EventBus.Client
@using Solace.LauncherUI.Programs
@using Solace.LauncherUI.Utils
@using Solace.ObjectStore.Client
@attribute [Authorize(Policy = Permissions.ManagePlayers)]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject ServerManager ServerManager
@inject EarthDbContext EarthDb

<PageTitle>Player Buildplates - Solace</PageTitle>

<div class="container-fluid py-3 px-md-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <a href="/Admin/Players" class="btn btn-link text-decoration-none p-0 mb-2">
            <i class="bi bi-arrow-left"></i> Back to Players
        </a>
        <div class="d-flex align-items-baseline gap-2">
            <h2 class="mb-0">
                <i class="bi bi-boxes text-info me-2"></i>
                Buildplates for Player @(string.IsNullOrEmpty(_username) ? $"with id {AccountId}" : $"{_username} (ID: {AccountId})")
            </h2>
        </div>
        
        <button class="btn btn-primary fw-bold" @onclick="OpenAddModal">
            <i class="bi bi-plus-lg"></i> Add Buildplate
        </button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-octagon-fill me-2"></i>
            <strong>Error:</strong> @_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = null" aria-label="Close"></button>
        </div>
    }

    @if (_playerBuildplates is not null && _playerBuildplates.Any())
    {
        <div class="row mb-4">
            <div class="col-12 col-md-6 col-lg-4">
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search player buildplates..." value="@_playerSearchTerm" @oninput="HandlePlayerSearch" />
                </div>
            </div>
        </div>
    }

    <div class="row g-4">
        @if (_playerBuildplates is null)
        {
            <div class="col-12">
                <div class="alert alert-info">
                    Loading player buildplates...
                </div>
            </div>
        }
        else if (!_playerBuildplates.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    This player doesn't have any buildplates yet.
                </div>
            </div>
        }
        else if (!FilteredPlayerBuildplates.Any())
        {
            <div class="col-12">
                <div class="alert alert-warning shadow-sm border-0">
                    <i class="bi bi-info-circle me-2"></i> No buildplates match your search criteria.
                </div>
            </div>
        }
        else
        {
            @foreach (var bp in PaginatedPlayerBuildplates)
            {
                float scaleVal = 1f / bp.BlocksPerMeter;
                string displayScale = scaleVal >= 1
                    ? $"1:{scaleVal:0.##}"
                    : $"{(1 / scaleVal):0.##}:1";

                <div class="col-12 col-md-6 col-lg-4 col-xl-3" @key="@bp.Id">
                    <div class="card h-100 shadow-sm @(bp.IsBusy ? "opacity-50" : "")">
                        <BuildplatePreview BuildplateId="@bp.Id" IsTemplate=false PlayerId="@AccountId" Size="@bp.Size" BlocksPerMeter="@bp.BlocksPerMeter" IsNight="@bp.IsNight" ResourcePackManager="@_resourcePackManager" />
                        
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(bp.ErrorMessage))
                            {
                                <div class="alert alert-danger alert-dismissible fade show small py-2" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                    @bp.ErrorMessage
                                    <button type="button" class="btn-close small" style="padding: 0.75rem" @onclick="() => bp.ErrorMessage = null"></button>
                                </div>
                            }
                            
                            <div class="mb-3">
                                <label class="form-label visually-hidden">Buildplate Name</label>
                                <input type="text" minlength="1" maxlength="100" class="form-control fw-bold border-0 bg-light" @bind="bp.Name" @bind:event="oninput" disabled="@(!HasPermission(Permissions.ManagePlayers) || bp.IsBusy)" />
                            </div>

                            <div class="row text-muted small">
                                <div class="col-6 mb-2">
                                    <span class="d-block fw-bold text-uppercase">Size</span>
                                    <span>@(bp.Size)x@(bp.Size)</span>
                                </div>
                                <div class="col-6 mb-2">
                                    <span class="d-block fw-bold text-uppercase">BPM</span>
                                    <input type="number" min="1" max="100" class="form-control form-control-sm border-0 bg-light" @bind="bp.BlocksPerMeter" @bind:event="oninput" disabled="@(!HasPermission(Permissions.ManagePlayers) || bp.IsBusy)" />
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 pb-3 d-flex flex-column gap-2">
                            <div class="d-flex justify-content-between align-items-center">
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => OpenRemoveBuildplateModal(bp.Id)" disabled="@bp.IsBusy">
                                    <i class="bi bi-trash me-1"></i> Remove
                                </button>

                                @if (bp.IsDirty || bp.IsSaving)
                                {
                                    <button class="btn btn-success btn-sm fw-bold" @onclick="() => SaveBuildplate(bp)" disabled="@bp.IsBusy">
                                        @if (bp.IsSaving)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1"></span>
                                        }
                                        Save
                                    </button>
                                }
                            </div>
                            
                            <button class="btn btn-outline-primary btn-sm w-100 fw-bold" @onclick="() => RegeneratePreview(bp)" disabled="@bp.IsBusy">
                                @if (bp.IsRegeneratingPreview)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                    <span>Regenerating...</span>
                                }
                                else
                                {
                                    <i class="bi bi-gear-fill me-1"></i>
                                    <span>Regenerate In-Game Preview</span>
                                }
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    @if (TotalPlayerPages > 1)
    {
        <nav aria-label="Player buildplates pagination" class="mt-4 d-flex justify-content-center">
            <ul class="pagination mb-0">
                <li class="page-item @(_playerCurrentPage <= 1 ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePlayerPage(_playerCurrentPage - 1)">
                        &laquo;Prev
                    </button>
                </li>
                <li class="page-item disabled">
                    <span class="page-link text-dark fw-semibold bg-light">
                        Page @_playerCurrentPage of @TotalPlayerPages
                    </span>
                </li>
                <li class="page-item @(_playerCurrentPage >= TotalPlayerPages ? "disabled" : "")">
                    <button class="page-link" @onclick="() => ChangePlayerPage(_playerCurrentPage + 1)">
                        Next&raquo;
                    </button>
                </li>
            </ul>
        </nav>
    }
</div>

@if (_showAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Template Buildplate</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <div class="modal-body bg-light">
                    <div class="input-group mb-4 shadow-sm">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Search templates by name..." @bind="_searchTerm" @bind:event="oninput" @onkeyup="HandleSearchKeyUp" />
                        <button class="btn btn-primary" type="button" @onclick="PerformSearch">Search</button>
                    </div>

                    @if (_isLoadingTemplates || _templates is null)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border text-primary" role="status"></div>
                            <div class="mt-2 text-muted">Loading templates...</div>
                        </div>
                    }
                    else if (!_templates.Any())
                    {
                        <div class="alert alert-warning shadow-sm border-0">
                            <i class="bi bi-info-circle me-2"></i> No template buildplates found matching your search criteria.
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var template in _templates)
                            {
                                <div class="col-12 col-md-6 col-lg-4" @key="template.Id">
                                    <div class="card h-100 shadow-sm @(template.IsAdding ? "opacity-75" : "")">
                                        <div class="position-relative rounded-top" style="aspect-ratio: 16 / 9; overflow: visible;">
                                            <BuildplatePreview BuildplateId="@template.Id" IsTemplate=true Size="@template.Size" BlocksPerMeter="@template.BlocksPerMeter" IsNight="@template.IsNight" ResourcePackManager="@_resourcePackManager" />
                                        </div>
                                        <div class="card-body p-3 d-flex flex-column">
                                            <h6 class="mb-1 fw-bold text-truncate" title="@template.Name">@template.Name</h6>
                
                                            @if (!string.IsNullOrEmpty(template.ErrorMessage))
                                            {
                                                <div class="alert alert-danger py-1 px-2 small d-flex justify-content-between align-items-center mb-2">
                                                    <span><i class="bi bi-x-circle me-1"></i> @template.ErrorMessage</span>
                                                    <button type="button" class="btn-close small" style="font-size: 0.5rem" @onclick="() => template.ErrorMessage = null"></button>
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(template.SuccessMessage))
                                            {
                                                <div class="alert alert-success py-1 px-2 small mb-2">
                                                    <i class="bi bi-check-circle me-1"></i> @template.SuccessMessage
                                                </div>
                                            }

                                            <small class="text-muted mb-3 d-block">
                                                Size: @(template.Size)x@(template.Size) | BPM: @template.BlocksPerMeter
                                            </small>

                                            <button class="btn btn-sm btn-success mt-auto fw-bold" @onclick="async () => await AddBuildplateFromTemplate(template)" disabled="@template.IsAdding">
                                                @if (template.IsAdding)
                                                {
                                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                                    <span>Adding...</span>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-plus-circle me-1"></i>
                                                    <span>Add</span>
                                                }
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer d-flex justify-content-between align-items-center">
                    <div>
                        @if (TotalPages > 1)
                        {
                            <nav aria-label="Template search pagination">
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(_currentPage <= 1 ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(_currentPage - 1)">&laquo;
                                            Prev
                                        </button>
                                    </li>
                                    <li class="page-item disabled">
                                        <span class="page-link text-dark fw-semibold bg-light">Page @_currentPage of
                                            @TotalPages
                                        </span>
                                    </li>
                                    <li class="page-item @(_currentPage >= TotalPages ? "disabled" : "")">
                                        <button class="page-link" @onclick="() => ChangePage(_currentPage + 1)">
                                            Next&raquo;
                                        </button>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                    <button type="button" class="btn btn-secondary" @onclick="CloseAddModal">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.6);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-danger shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Removal</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseDeleteModal"></button>
                </div>
                <div class="modal-body py-4 text-center">
                    <p class="mb-1">Are you sure you want to remove this buildplate from the player?</p>
                    <strong class="fs-5">@_nameToDelete</strong>
                    <div class="text-muted small mt-2">This action cannot be undone.</div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button type="button" class="btn btn-danger px-4" @onclick="ConfirmDelete">Remove Buildplate</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public required Guid AccountId { get; set; }

    private ClaimsPrincipal? _user;
    private string? _username;

    private ResourcePackManager _resourcePackManager = null!;

    // State
    private List<PlayerBuildplate>? _playerBuildplates;
    private List<TemplateDto>? _templates;
    private bool _showAddModal = false;
    private string? _errorMessage;

    private string _playerSearchTerm = "";
    private int _playerCurrentPage = 1;
    private int _playerPageSize = 8;

    private IEnumerable<PlayerBuildplate> FilteredPlayerBuildplates
        => _playerBuildplates?.Where(bp => string.IsNullOrWhiteSpace(_playerSearchTerm) || bp.Name.Contains(_playerSearchTerm,
StringComparison.OrdinalIgnoreCase))
        ?? Array.Empty<PlayerBuildplate>();

    private int TotalPlayerPages => Math.Max(1, (int)Math.Ceiling((double)FilteredPlayerBuildplates.Count() /
_playerPageSize));

    private IEnumerable<PlayerBuildplate> PaginatedPlayerBuildplates =>
        FilteredPlayerBuildplates.Skip((_playerCurrentPage - 1) * _playerPageSize).Take(_playerPageSize);

    private void HandlePlayerSearch(ChangeEventArgs e)
    {
        _playerSearchTerm = e.Value?.ToString() ?? "";
        _playerCurrentPage = 1; // Reset to page 1 on new search
    }

    private void ChangePlayerPage(int newPage)
    {
        if (newPage >= 1 && newPage <= TotalPlayerPages)
        {
            _playerCurrentPage = newPage;
        }
    }

    // Search and Pagination State for Templates
    private string? _searchTerm = "";
    private int _currentPage = 1;
    private int _pageSize = 6;
    private int _totalCount = 0;
    private bool _isLoadingTemplates = false;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)_totalCount / _pageSize));

    // State for Deletion
    private bool _showDeleteModal = false;
    private Guid? _idToDelete;
    private string? _nameToDelete;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _user = authState.User;

        _resourcePackManager = await ResourcePackManagerSingleton.GetResourcePackManagerAsync();

        try
        {
            _username = (await EarthDb.Accounts.AsNoTracking().FirstOrDefaultAsync(account => account.Id == AccountId))?.Username;
        }
        catch (Exception ex)
        {
            Log.Error(ex, $"Failed to get username for player '{AccountId}': {ex.Message}");
        }

        await LoadPlayerBuildplates();
        await LoadBuildplateTemplates(); // Load initial page
    }

    private async Task LoadPlayerBuildplates()
    {
        _errorMessage = null; // Clear previous errors

        var buildplates = EarthDb.PlayerBuildplates
            .AsNoTracking()
            .Where(buildplate => buildplate.AccountId == AccountId);

        _playerBuildplates = new(await buildplates.CountAsync());
        foreach (var buildplate in buildplates)
        {
            var bp = new PlayerBuildplate()
            {
                Id = buildplate.Id,
                Name = buildplate.Name,
                Size = buildplate.Size,
                BlocksPerMeter = buildplate.Scale,
                IsNight = buildplate.Night,
                ServerDataObjectId = buildplate.ServerDataObjectId,
                PreviewObjectId = buildplate.PreviewObjectId,
            };

            bp.AcceptChanges();
            _playerBuildplates.Add(bp);
        }
    }

    private async Task PerformSearch()
    {
        _currentPage = 1;
        await LoadBuildplateTemplates();
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key is "Enter")
        {
            await PerformSearch();
        }
    }

    private async Task ChangePage(int newPage)
    {
        if (newPage < 1 || newPage > TotalPages)
        {
            return;
        }
        
        _currentPage = newPage;
        await LoadBuildplateTemplates();
    }

    private async Task LoadBuildplateTemplates()
    {
        _isLoadingTemplates = true;
        
        StateHasChanged();

        try
        {
            int skip = (_currentPage - 1) * _pageSize;
            string? searchFilter = string.IsNullOrWhiteSpace(_searchTerm) ? null : _searchTerm.Trim();

            var query = (IQueryable<DB.Models.Global.TemplateBuildplateEF>)EarthDb.TemplateBuildplates;

            if (!string.IsNullOrWhiteSpace(searchFilter))
            {
                query = query.Where(buildplate => buildplate.Name.Contains(searchFilter));
            }

            _totalCount = await query.CountAsync();

            var buildplates = await query
                .Skip(skip)
                .Take(_pageSize)
                .ToListAsync();

            _templates = new List<TemplateDto>(buildplates.Count);

            foreach (var dbBp in buildplates)
            {
                _templates.Add(new TemplateDto
                {
                    Id = dbBp.Id,
                    Name = dbBp.Name,
                    Size = dbBp.Size,
                    BlocksPerMeter = dbBp.Scale,
                    IsNight = dbBp.Night,
                    ServerDataObjectId = dbBp.ServerDataObjectId,
                });
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Could not load templates for player assignment: {ex}");
            _templates = new List<TemplateDto>();
            _totalCount = 0;
        }
        finally
        {
            _isLoadingTemplates = false;
            StateHasChanged(); // Ensure loading spinner is removed
        }
    }

    private void OpenAddModal()
        => _showAddModal = true;

    private void CloseAddModal()
        => _showAddModal = false;

    private async Task AddBuildplateFromTemplate(TemplateDto template)
    {
        if (_playerBuildplates is null || template.IsAdding)
        {
            return;
        }

        template.IsAdding = true;
        template.ErrorMessage = null;
        template.SuccessMessage = null;
        StateHasChanged();

        if (!await ServerManager.EnsureComponentsOnline(EventBusServer.ExeName, ObjectStoreServer.ExeName,
BuildplateLauncher.ExeName))
        {
            template.ErrorMessage = "The server must be running.";
            template.IsAdding = false;
            return;
        }

        try
        {
            await using var importer = await Importer.CreateFromSettings(Settings.Instance, EarthDb, Log.Logger);

            var buildplateIdNullable = await importer.AddBuidplateToPlayer(template.Id, AccountId, default);
            if (buildplateIdNullable is null)
            {
                template.ErrorMessage = $"The importer failed to add template '{template.Name}' to the player.";
                return;
            }

            var buildplateId = buildplateIdNullable.Value;

            var dbBuildplate = await EarthDb.PlayerBuildplates
                .AsNoTracking()
                .FirstAsync(buildplate => buildplate.Id == buildplateId && buildplate.AccountId == AccountId);

            var buildplate = new PlayerBuildplate
            {
                Id = buildplateId,
                Name = template.Name,
                Size = template.Size,
                BlocksPerMeter = template.BlocksPerMeter,
                IsNight = template.IsNight,
                ServerDataObjectId = dbBuildplate.ServerDataObjectId,
                PreviewObjectId = dbBuildplate.PreviewObjectId,
            };

            buildplate.AcceptChanges();

            _playerBuildplates.Add(buildplate);

            template.SuccessMessage = "Added successfully!";
            
            _ = Task.Delay(3000).ContinueWith(_ =>
            {
                template.SuccessMessage = null;
                InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to add buildplate '{template.Id}' to player '{AccountId}': {ex}");
            template.ErrorMessage = $"An error occurred while importing the buildplate: {ex.Message}";
        }
        finally
        {
            template.IsAdding = false;
            StateHasChanged();
        }
    }

    private async Task OpenRemoveBuildplateModal(Guid id)
    {
        _errorMessage = null;

        var item = _playerBuildplates?.FirstOrDefault(x => x.Id == id);
        if (item is not null)
        {
            if (!await ServerManager.EnsureComponentsOnline(ObjectStoreServer.ExeName))
            {
                _errorMessage = "The server must be running.";
                return;
            }

            _idToDelete = id;
            _nameToDelete = item.Name;
            _showDeleteModal = true;
        }
    }

    private async Task ConfirmDelete()
    {
        if (_idToDelete is not null && _playerBuildplates is not null)
        {
            var item = _playerBuildplates.FirstOrDefault(x => x.Id == _idToDelete);
            if (item is not null)
            {
                try
                {
                    if (await RemoveBuildplate(_idToDelete.Value))
                    {
                        _playerBuildplates.Remove(item);
                        
                        // Handle edge case where deleting leaves the current page empty
                        if (_playerCurrentPage > TotalPlayerPages)
                        {
                            _playerCurrentPage = TotalPlayerPages;
                        }
                    }
                    else
                    {
                        _errorMessage = $"An error occurred while removing the buildplate.";
                    }
                }
                catch (Exception ex)
                {
                    Log.Error($"Failed to remove buildplate '{_idToDelete}' from player '{AccountId}': {ex}");
                    _errorMessage = $"An error occurred while removing the buildplate: {ex.Message}";
                }
            }
        }

        CloseDeleteModal();
    }

    private async Task<bool> RemoveBuildplate(Guid id)
    {
        await using var importer = await Importer.CreateFromSettings(Settings.Instance, EarthDb, Log.Logger);

        return await importer.RemoveBuildplateFromPlayer(id, AccountId, default);
    }

    private void CloseDeleteModal()
    {
        _showDeleteModal = false;
        _idToDelete = null;
        _nameToDelete = null;
    }

    private async Task SaveBuildplate(PlayerBuildplate bp)
    {
        if (!HasPermission(Permissions.ManagePlayers))
        {
            return;
        }

        bp.IsSaving = true;
        bp.ErrorMessage = null;
        bp.Name = bp.Name.Trim();

        if (string.IsNullOrEmpty(bp.Name))
        {
            bp.ErrorMessage = "Name cannot be empty.";
            bp.IsSaving = false;
            return;
        }

        try
        {
            var dbBuildplate = await EarthDb.PlayerBuildplates
                .AsTracking()
                .FirstOrDefaultAsync(buildplate => buildplate.Id == bp.Id && buildplate.AccountId == AccountId);

            if (dbBuildplate is not null)
            {
                dbBuildplate.Name = bp.Name;
                dbBuildplate.Scale = bp.BlocksPerMeter;

                await EarthDb.SaveChangesAsync();

                await Task.Delay(250);
                
                bp.AcceptChanges();
                Log.Information($"Successfully updated buildplate {bp.Id} for player {AccountId}");
            }
            else
            {
                bp.ErrorMessage = "Buildplate not found in database.";
            }
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to save buildplate '{bp.Id}' for player '{AccountId}': {ex}");
            bp.ErrorMessage = "Failed to save. Try again?";
        }
        finally
        {
            bp.IsSaving = false;
        }
    }

    private async Task RegeneratePreview(PlayerBuildplate bp)
    {
        if (!HasPermission(Permissions.ManagePlayers))
        {
            return;
        }

        bp.IsRegeneratingPreview = true;
        bp.ErrorMessage = null;

        if (!await ServerManager.EnsureComponentsOnline(EventBusServer.ExeName, ObjectStoreServer.ExeName,
BuildplateLauncher.ExeName))
        {
            bp.ErrorMessage = "The server must be running.";
            bp.IsRegeneratingPreview = false;
            return;
        }

        try
        {
            await using var importer = await Importer.CreateFromSettings(Settings.Instance, EarthDb, Log.Logger);

            if (!await importer.RegeneratePlayerBuildplatePreviewAsync(AccountId, bp.Id, default))
            {
                bp.ErrorMessage = "Failed to regenerate preview, check Launcher logs for details.";
                return;
            }

            var buildplate = await EarthDb.PlayerBuildplates
                .AsNoTracking()
                .FirstAsync(buildplate => buildplate.Id == bp.Id && buildplate.AccountId == AccountId);

            bp.ServerDataObjectId = buildplate.ServerDataObjectId;

            Log.Information($"Successfully regenerated preview for player buildplate {bp.Id}");
        }
        catch (Exception ex)
        {
            Log.Error($"Failed to regenerate preview for player buildplate '{bp.Id}': {ex}");
            bp.ErrorMessage = "Failed to regenerate preview. Try again?";
        }
        finally
        {
            bp.IsRegeneratingPreview = false;
        }
    }

    private bool HasPermission(string permission)
        => _user?.HasPermission(permission) ?? false;

    public sealed class PlayerBuildplate
    {
        public required Guid Id { get; set; }
        public required string Name { get; set; }
        public int Size { get; set; }
        public int BlocksPerMeter { get; set; }
        public bool IsNight { get; set; }

        public required string ServerDataObjectId { get; set; }
        public required string PreviewObjectId { get; set; }

        // Change Tracking
        private string? _originalName;
        private int _originalBlocksPerMeter = -1;

        public bool IsDirty => Name != _originalName || BlocksPerMeter != _originalBlocksPerMeter;

        // UI State
        public bool IsSaving { get; set; }
        public bool IsRegeneratingPreview { get; set; }
        public bool IsBusy => IsSaving || IsRegeneratingPreview;
        public string? ErrorMessage { get; set; }

        public void AcceptChanges()
        {
            _originalName = Name;
            _originalBlocksPerMeter = BlocksPerMeter;
        }
    }

    public sealed class TemplateDto
    {
        public required Guid Id { get; set; }
        public required string Name { get; set; }
        public int Size { get; set; }
        public int BlocksPerMeter { get; set; }
        public bool IsNight { get; set; }
        
        public required string ServerDataObjectId { get; set; }
        
        public bool IsAdding { get; set; }
        public string? ErrorMessage { get; set; }
        public string? SuccessMessage { get; set; }
    }
}